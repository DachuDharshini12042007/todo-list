<!DOCTYPE html>
<html>
<head>
<title>Login</title>
<style>
body{
 margin:0;
 height:100vh;
 display:flex;
 justify-content:center;
 align-items:center;
 background:linear-gradient(135deg,#667eea,#764ba2);
 font-family:Segoe UI;
}
.login{
 background:#0f3057;
 padding:30px;
 width:320px;
 border-radius:15px;
 box-shadow:0 20px 40px rgba(0,0,0,.4);
 color:white;
}
.login h2{text-align:center;}
.login input{
 width:100%;
 padding:10px;
 margin:10px 0;
 border:none;
 border-radius:8px;
}
.login button{
 width:100%;
 padding:10px;
 background:#00b4d8;
 border:none;
 color:white;
 border-radius:8px;
 font-size:16px;
 cursor:pointer;
}
</style>
</head>
<body>

<div class="login">
<h2>Login</h2>
<input type="text" placeholder="Username">
<input type="password" placeholder="Password">
<button onclick="location.href='home.html'">Login</button>
</div>

</body>
</html>